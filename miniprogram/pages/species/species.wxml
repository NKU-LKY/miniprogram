<navigation-bar title="物种档案" back="{{true}}" color="black" background="#F5F9F0"></navigation-bar>

<scroll-view class="page" scroll-y type="list">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="unavailable" wx:elif="{{unavailable}}">
    <text class="unavailable-icon">🌿</text>
    <text class="unavailable-title">暂无该物种档案</text>
    <text class="unavailable-desc">可能还没有带物种标注的观测记录</text>
  </view>

  <block wx:elif="{{detail}}">
    <view class="hero-card">
      <text class="hero-icon">{{detail.marker_label}}</text>
      <view class="hero-meta">
        <text class="hero-name">{{detail.species_name}}</text>
        <text class="hero-count">共 {{detail.record_count}} 条观测记录</text>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">照片墙</text>
      <view class="photo-wall">
        <view
          class="photo-item"
          wx:for="{{detail.photo_wall}}"
          wx:key="obs_id"
          data-index="{{index}}"
          bindtap="onPreviewPhoto"
        >
          <image class="photo-image" src="{{item.photo_url}}" mode="aspectFill"></image>
          <text class="photo-time">{{item.time_text}}</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">常出现地点</text>
      <view class="location-list" wx:if="{{detail.common_locations.length > 0}}">
        <view class="location-item" wx:for="{{detail.common_locations}}" wx:key="name">
          <view class="location-row">
            <text class="location-name">📍 {{item.name}}</text>
            <text class="location-count">{{item.count}} 次</text>
          </view>
          <view class="location-bar-track">
            <view
              class="location-bar-fill"
              style="width: {{item.count / maxLocationCount * 100}}%;"
            ></view>
          </view>
        </view>
      </view>
      <text class="section-empty" wx:else>暂无地点数据</text>
    </view>

    <view class="section-card" wx:if="{{detail.is_animal}}">
      <text class="section-title">活跃时段</text>
      <view class="active-period">
        <text class="active-icon">🕐</text>
        <text class="active-text">{{detail.active_periods}}</text>
      </view>
      <text class="active-hint">根据校园观测记录汇总，仅供参考</text>
    </view>

    <view class="section-card">
      <text class="section-title">相关记录</text>
      <view
        class="record-item"
        wx:for="{{detail.related_records}}"
        wx:key="obs_id"
        data-id="{{item.obs_id}}"
        bindtap="onRecordTap"
      >
        <image class="record-thumb" src="{{item.photo_url}}" mode="aspectFill"></image>
        <view class="record-body">
          <text class="record-note">{{item.note}}</text>
          <view class="record-meta">
            <text class="record-location">📍 {{item.location_name}}</text>
            <text class="record-time">{{item.time_text}}</text>
          </view>
          <text class="record-like">♥ {{item.like_count}}</text>
        </view>
      </view>
    </view>
  </block>
</scroll-view>
