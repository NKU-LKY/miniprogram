<navigation-bar title="发布观测" back="{{true}}" color="black" background="#F5F9F0"></navigation-bar>

<view class="page">
  <view class="photo-section" bindtap="onChoosePhoto">
    <image
      wx:if="{{photoPath}}"
      class="photo-preview"
      src="{{photoPath}}"
      mode="aspectFill"
    ></image>
    <view class="photo-placeholder" wx:else>
      <text class="photo-icon">📷</text>
      <text class="photo-tip">点击上传照片</text>
      <text class="photo-sub">拍摄或从相册选择</text>
    </view>
  </view>

  <view class="form-card">
    <view class="field">
      <text class="field-label">一句话描述</text>
      <textarea
        class="field-textarea"
        placeholder="说说你看到了什么……"
        maxlength="200"
        value="{{note}}"
        bindinput="onNoteInput"
        auto-height
        show-confirm-bar="{{false}}"
      ></textarea>
    </view>

    <view class="field">
      <text class="field-label">观测地点</text>
      <view class="location-row">
        <view class="location-display">
          <text class="location-icon">📍</text>
          <text wx:if="{{locating}}" class="location-text muted">正在定位…</text>
          <text wx:elif="{{resolvingName}}" class="location-text muted">正在解析地点…</text>
          <text wx:elif="{{locationName}}" class="location-text">{{locationName}}</text>
          <text wx:else class="location-text muted">{{locationFailed ? '定位失败，请在地图上选择' : '等待定位'}}</text>
        </view>
        <view class="relocate-btn {{locating || resolvingName ? 'disabled' : ''}}" bindtap="locateByDevice">
          <text>{{locating ? '定位中' : resolvingName ? '解析中' : '重新定位'}}</text>
        </view>
      </view>
      <view class="map-picker-btn" bindtap="onOpenMapPicker">
        <text class="map-picker-icon">🗺</text>
        <text class="map-picker-text">在地图上选择地点</text>
        <text class="map-picker-arrow">›</text>
      </view>
      <input
        class="field-input location-detail-input"
        placeholder="详细地址（选填），如：东门花坛旁第三棵银杏"
        maxlength="100"
        value="{{locationDetail}}"
        bindinput="onLocationDetailInput"
      />
    </view>

    <view class="field">
      <text class="field-label">物种类别（选填）</text>
      <picker
        mode="selector"
        range="{{speciesCategories}}"
        range-key="name"
        value="{{speciesCategoryIndex >= 0 ? speciesCategoryIndex : 0}}"
        bindchange="onSpeciesCategoryChange"
      >
        <view class="picker-display">
          <text wx:if="{{speciesCategoryName}}" class="picker-value">{{speciesCategoryName}}</text>
          <text wx:else class="picker-placeholder">选择大类，如：鸟类</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
      <view class="picker-clear" wx:if="{{speciesCategoryName}}" bindtap="onClearSpeciesCategory">
        <text>清除类别</text>
      </view>
    </view>

    <view class="field" wx:if="{{speciesCategoryName || needsIdentification}}">
      <text class="field-label">物种备注（选填）</text>
      <input
        class="field-input"
        placeholder="填写具体物种信息，如：喜鹊、麻雀"
        maxlength="30"
        value="{{speciesRemark}}"
        bindinput="onSpeciesRemarkInput"
      />
    </view>

    <view class="switch-row">
      <view class="switch-meta">
        <text class="switch-title">不确定是什么物种？求鉴定</text>
        <text class="switch-desc">开启后将进入待鉴定队列</text>
      </view>
      <switch
        checked="{{needsIdentification}}"
        color="#4c8c4a"
        bindchange="onIdentificationChange"
      />
    </view>

    <view class="switch-row">
      <view class="switch-meta">
        <text class="switch-title">暂存填写内容</text>
        <text class="switch-desc">保存到本地，下次打开自动恢复，发布后清除</text>
      </view>
      <switch
        checked="{{saveDraftEnabled}}"
        color="#4c8c4a"
        bindchange="onDraftToggle"
      />
    </view>
  </view>

  <button class="btn-publish" loading="{{submitting}}" bindtap="onPublish">发布</button>
</view>
