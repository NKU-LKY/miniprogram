<navigation-bar title="观测详情" back="{{true}}" color="black" background="#F5F9F0"></navigation-bar>

<view class="page-wrap" wx:if="{{!loading && !unavailable && detail}}">
  <scroll-view class="page" scroll-y type="list">
    <view class="photo-section" bindtap="onPreviewPhoto">
      <image class="hero-photo" src="{{detail.photo_url}}" mode="aspectFill"></image>
      <view class="featured-ribbon" wx:if="{{detail.is_featured}}">⭐ 精选</view>
      <text class="photo-hint">点击查看大图</text>
    </view>

    <view class="rejected-banner" wx:if="{{detail.is_rejected}}">
      <text class="rejected-title">该记录已被隐藏</text>
      <text class="rejected-desc">该内容不再对外展示，如有异议可提交申诉</text>
    </view>

    <view class="appeal-panel" wx:if="{{showAppealPanel}}">
      <text class="panel-title">提交申诉</text>

      <view class="appeal-status pending" wx:if="{{appeal && appeal.status === 'pending'}}">
        <text class="appeal-status-title">{{appeal.status_label}}</text>
        <text class="appeal-status-desc">申诉原因：{{appeal.reason}}</text>
        <text class="appeal-status-time">提交于 {{appeal.time_text}}</text>
      </view>

      <view class="appeal-status rejected" wx:elif="{{appeal && appeal.status === 'rejected'}}">
        <text class="appeal-status-title">{{appeal.status_label}}</text>
        <text class="appeal-status-desc">你可以修改申诉原因后重新提交</text>
      </view>

      <block wx:if="{{canSubmitAppeal}}">
        <textarea
          class="appeal-textarea"
          placeholder="请说明申诉原因，如认为记录符合平台规范等"
          maxlength="500"
          value="{{appealInput}}"
          bindinput="onAppealInput"
        />
        <view
          class="appeal-submit {{appealInput ? 'active' : ''}}"
          bindtap="onSubmitAppeal"
        >提交申诉</view>
      </block>
    </view>

    <view class="identification-panel" wx:if="{{showIdentificationPanel && identification}}">
      <text class="panel-title">物种鉴定</text>

      <view class="panel-hint claimed-other" wx:if="{{identification.claimed_by_other}}">
        <text>该记录已被 {{identification.reviewer_nickname}} 认领，暂不可操作</text>
      </view>

      <block wx:else>
        <view class="panel-hint" wx:if="{{identification.claimed_by_me}}">
          <text>你已认领此记录，请填写物种名称完成鉴定</text>
        </view>
        <view class="panel-hint" wx:elif="{{identification.can_claim}}">
          <text>请先认领此记录，再进行物种鉴定</text>
        </view>

        <view class="identify-form" wx:if="{{identification.can_identify}}">
          <view class="form-field">
            <text class="field-label">鉴定物种 *</text>
            <input
              class="field-input"
              placeholder="填写正式物种名称，如：麻雀"
              maxlength="30"
              value="{{speciesInput}}"
              bindinput="onSpeciesInput"
            />
          </view>
          <view class="form-field">
            <text class="field-label">鉴定备注</text>
            <input
              class="field-input"
              placeholder="可选，如鉴定依据或补充说明"
              maxlength="100"
              value="{{reviewNoteInput}}"
              bindinput="onReviewNoteInput"
            />
          </view>
        </view>

        <view class="panel-actions">
          <view
            wx:if="{{identification.can_claim}}"
            class="panel-btn claim"
            bindtap="onClaimIdentification"
          >认领此记录</view>
          <view
            wx:if="{{identification.can_release}}"
            class="panel-btn release"
            bindtap="onReleaseIdentification"
          >释放认领</view>
          <view
            wx:if="{{identification.can_identify}}"
            class="panel-btn submit {{speciesInput ? 'active' : ''}}"
            bindtap="onSubmitIdentification"
          >提交鉴定</view>
        </view>
      </block>
    </view>

    <view class="owner-bar" wx:if="{{isOwner}}">
      <view class="owner-btn comments-toggle" bindtap="onToggleComments">
        {{commentsEnabled ? '关闭评论区' : '开启评论区'}}
      </view>
      <view class="owner-btn withdraw" bindtap="onWithdrawObservation">撤回此记录</view>
    </view>

    <view class="admin-bar" wx:if="{{isAdmin}}">
      <view
        wx:if="{{!isHidden}}"
        class="admin-btn featured {{isFeatured ? 'active' : ''}}"
        bindtap="onToggleFeatured"
      >{{isFeatured ? '取消精选' : '设为精选'}}</view>
      <view
        wx:if="{{!isHidden}}"
        class="admin-btn hide"
        bindtap="onHideObservation"
      >隐藏此记录</view>
      <view
        wx:else
        class="admin-btn restore"
        bindtap="onRestoreObservation"
      >恢复此记录</view>
    </view>

    <view class="publisher-card">
      <image class="publisher-avatar" src="{{detail.publisher_avatar_url}}" mode="aspectFill"></image>
      <view class="publisher-meta">
        <text class="publisher-name">{{detail.publisher_nickname}}</text>
        <text class="publisher-time">{{detail.time_full}} · {{detail.time_text}}</text>
      </view>
    </view>

    <view class="content-card">
      <text class="note-text">{{detail.note}}</text>

      <view class="meta-row">
        <text class="meta-item">📍 {{detail.location_name}}</text>
        <text class="meta-item" wx:if="{{detail.species_name}}">🌿 {{detail.species_name}}</text>
      </view>
      <view class="location-detail-row" wx:if="{{detail.location_detail}}">
        <text class="location-detail-text">{{detail.location_detail}}</text>
      </view>

      <view class="status-row" wx:if="{{detail.status_label}}">
        <text class="status-tag">{{detail.status_label}}</text>
      </view>

      <view class="stats-row">
        <view class="stat-action {{detail.liked ? 'liked' : ''}}" bindtap="onToggleLike">
          <text class="stat-icon">{{detail.liked ? '♥' : '♡'}}</text>
          <text class="stat-text">{{detail.like_count}}</text>
        </view>
        <view class="stat-action readonly">
          <text class="stat-icon">💬</text>
          <text class="stat-text">{{detail.comment_count}}</text>
        </view>
      </view>
    </view>

    <view class="comments-section">
      <text class="section-title" wx:if="{{commentsEnabled}}">评论 {{detail.comment_count}}</text>
      <text class="section-title" wx:else>该记录的评论区已关闭</text>

      <view class="comment-list" wx:if="{{comments.length > 0}}">
        <view class="comment-thread" wx:for="{{comments}}" wx:key="comment_id">
          <view class="comment-item">
            <image class="comment-avatar" src="{{item.author_avatar_url}}" mode="aspectFill"></image>
            <view class="comment-body">
              <view class="comment-top">
                <text class="comment-author">{{item.author_nickname}}</text>
                <text class="expert-tag" wx:if="{{item.is_expert}}">认证专家</text>
                <text class="comment-time">{{item.time_text}}</text>
              </view>
              <text class="comment-content">{{item.content}}</text>
              <view class="comment-actions">
                <text
                  wx:if="{{commentsEnabled}}"
                  class="reply-btn"
                  data-id="{{item.comment_id}}"
                  data-nickname="{{item.author_nickname}}"
                  catchtap="onReplyComment"
                >回复</text>
                <view
                  wx:if="{{isAdmin}}"
                  class="comment-hide-btn"
                  data-id="{{item.comment_id}}"
                  bindtap="onHideComment"
                >隐藏</view>
              </view>
            </view>
          </view>

          <view class="reply-list" wx:if="{{item.replies.length > 0}}">
            <view class="reply-item" wx:for="{{item.replies}}" wx:for-item="reply" wx:key="comment_id">
              <image class="reply-avatar" src="{{reply.author_avatar_url}}" mode="aspectFill"></image>
              <view class="comment-body">
                <view class="comment-top">
                  <text class="comment-author">{{reply.author_nickname}}</text>
                  <text class="expert-tag" wx:if="{{reply.is_expert}}">认证专家</text>
                  <text class="comment-time">{{reply.time_text}}</text>
                </view>
                <text class="comment-content">
                  <text wx:if="{{reply.reply_to_nickname}}" class="reply-prefix">回复 @{{reply.reply_to_nickname}}：</text>{{reply.content}}
                </text>
                <view class="comment-actions">
                  <text
                    wx:if="{{commentsEnabled}}"
                    class="reply-btn"
                    data-id="{{reply.comment_id}}"
                    data-nickname="{{reply.author_nickname}}"
                    catchtap="onReplyComment"
                  >回复</text>
                  <view
                    wx:if="{{isAdmin}}"
                    class="comment-hide-btn"
                    data-id="{{reply.comment_id}}"
                    bindtap="onHideComment"
                  >隐藏</view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="comments-empty" wx:else>
        <text class="comments-empty-icon">💬</text>
        <text class="comments-empty-text" wx:if="{{commentsEnabled}}">暂无评论，快来抢沙发吧</text>
        <text class="comments-empty-text" wx:else>暂无评论</text>
      </view>
    </view>
  </scroll-view>

  <view class="comment-bar" wx:if="{{commentsEnabled}}">
    <view class="reply-banner" wx:if="{{replyTarget}}">
      <text class="reply-banner-text">回复 @{{replyTarget.author_nickname}}</text>
      <text class="reply-banner-cancel" bindtap="onCancelReply">取消</text>
    </view>
    <view class="comment-bar-row">
      <input
        class="comment-input"
        placeholder="{{commentPlaceholder}}"
        maxlength="200"
        value="{{commentInput}}"
        confirm-type="send"
        bindinput="onCommentInput"
        bindconfirm="onSubmitComment"
      />
      <view
        class="send-btn {{commentInput ? 'active' : ''}}"
        bindtap="onSubmitComment"
      >发送</view>
    </view>
  </view>
</view>

<scroll-view class="page page-fallback" scroll-y type="list" wx:else>
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="unavailable" wx:elif="{{unavailable}}">
    <text class="unavailable-icon">🔒</text>
    <text class="unavailable-title">该内容暂不可查看</text>
    <text class="unavailable-desc">记录可能已被隐藏或不存在</text>
  </view>
</scroll-view>
