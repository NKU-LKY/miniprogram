<navigation-bar title="内容管控" back="{{true}}" color="black" background="#F5F9F0"></navigation-bar>

<view class="page-body">
  <view class="forbidden" wx:if="{{forbidden}}">
    <text class="forbidden-icon">🔒</text>
    <text class="forbidden-title">无访问权限</text>
    <text class="forbidden-desc">仅管理员可进行内容管控</text>
  </view>

  <block wx:else>
    <view class="tab-bar">
      <view
        class="tab-item {{activeTab === 'observations' ? 'active' : ''}}"
        data-tab="observations"
        bindtap="onTabChange"
      >观测记录</view>
      <view
        class="tab-item {{activeTab === 'comments' ? 'active' : ''}}"
        data-tab="comments"
        bindtap="onTabChange"
      >评论</view>
      <view
        class="tab-item {{activeTab === 'appeals' ? 'active' : ''}}"
        data-tab="appeals"
        bindtap="onTabChange"
      >申诉{{appealPendingCount > 0 ? ' (' + appealPendingCount + ')' : ''}}</view>
    </view>

    <scroll-view class="scrollarea" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="loading" wx:if="{{loading}}">
        <text>加载中...</text>
      </view>

      <block wx:if="{{activeTab === 'observations' && !loading}}">
        <view class="obs-card" wx:for="{{obsList}}" wx:key="obs_id">
          <image
            class="obs-thumb"
            src="{{item.photo_url}}"
            mode="aspectFill"
            data-id="{{item.obs_id}}"
            bindtap="onGoDetail"
          ></image>
          <view class="obs-body">
            <text class="obs-note">{{item.note}}</text>
            <view class="obs-meta">
              <text class="meta-text">{{item.publisher_nickname}} · {{item.time_text}}</text>
              <text class="featured-tag" wx:if="{{item.is_featured}}">⭐ 精选</text>
              <text class="appeal-tag" wx:if="{{item.has_pending_appeal}}">📋 待处理申诉</text>
              <text class="status-tag {{item.is_hidden ? 'hidden' : ''}}">{{item.status_label}}</text>
            </view>
            <view class="action-row">
              <view
                wx:if="{{!item.is_hidden && !item.is_featured}}"
                class="action-btn featured"
                data-id="{{item.obs_id}}"
                data-action="set"
                bindtap="onToggleFeatured"
              >设为精选</view>
              <view
                wx:if="{{!item.is_hidden && item.is_featured}}"
                class="action-btn featured active"
                data-id="{{item.obs_id}}"
                data-action="unset"
                bindtap="onToggleFeatured"
              >取消精选</view>
              <view
                wx:if="{{!item.is_hidden}}"
                class="action-btn hide"
                data-id="{{item.obs_id}}"
                bindtap="onHideObservation"
              >隐藏</view>
              <view
                wx:elif="{{item.is_hidden && !item.has_pending_appeal}}"
                class="action-btn restore"
                data-id="{{item.obs_id}}"
                bindtap="onRestoreObservation"
              >恢复</view>
              <view
                wx:elif="{{item.is_hidden && item.has_pending_appeal}}"
                class="action-btn link"
                data-tab="appeals"
                bindtap="onGoAppealsTab"
              >查看申诉</view>
              <view class="action-btn link" data-id="{{item.obs_id}}" bindtap="onGoDetail">查看</view>
            </view>
          </view>
        </view>

        <view class="empty" wx:if="{{obsList.length === 0}}">
          <text>暂无观测记录</text>
        </view>
      </block>

      <block wx:if="{{activeTab === 'comments' && !loading}}">
        <view class="comment-card {{item.is_hidden ? 'hidden-comment' : ''}}" wx:for="{{commentList}}" wx:key="comment_id">
          <view class="comment-top">
            <view class="comment-meta-left">
              <text class="comment-author">{{item.author_nickname}}</text>
              <text class="status-tag hidden" wx:if="{{item.is_hidden}}">{{item.status_label || '已隐藏'}}</text>
            </view>
            <text class="comment-time">{{item.time_text}}</text>
          </view>
          <text class="comment-content">{{item.content}}</text>
          <view class="action-row">
            <view
              wx:if="{{!item.is_hidden}}"
              class="action-btn hide"
              data-id="{{item.comment_id}}"
              bindtap="onHideComment"
            >隐藏</view>
            <view
              wx:if="{{item.is_hidden}}"
              class="action-btn restore"
              data-id="{{item.comment_id}}"
              bindtap="onRestoreComment"
            >取消隐藏</view>
            <view class="action-btn link" data-id="{{item.obs_id}}" bindtap="onGoDetail">查看记录</view>
          </view>
        </view>

        <view class="empty" wx:if="{{commentList.length === 0}}">
          <text>暂无评论</text>
        </view>
      </block>

      <block wx:if="{{activeTab === 'appeals' && !loading}}">
        <view class="appeal-card" wx:for="{{appealList}}" wx:key="appeal_id">
          <image
            class="obs-thumb"
            src="{{item.photo_url}}"
            mode="aspectFill"
            data-id="{{item.obs_id}}"
            bindtap="onGoDetail"
          ></image>
          <view class="obs-body">
            <text class="obs-note">{{item.obs_note}}</text>
            <view class="obs-meta">
              <text class="meta-text">{{item.appellant_nickname}} · {{item.time_text}}</text>
            </view>
            <text class="appeal-reason">申诉原因：{{item.reason}}</text>
            <view class="action-row">
              <view
                class="action-btn restore"
                data-id="{{item.appeal_id}}"
                data-obs-id="{{item.obs_id}}"
                data-owner-id="{{item.appellant_user_id}}"
                bindtap="onApproveAppeal"
              >取消隐藏</view>
              <view
                class="action-btn hide"
                data-id="{{item.appeal_id}}"
                data-obs-id="{{item.obs_id}}"
                data-owner-id="{{item.appellant_user_id}}"
                bindtap="onRejectAppeal"
              >驳回申诉</view>
              <view class="action-btn link" data-id="{{item.obs_id}}" bindtap="onGoDetail">查看</view>
            </view>
          </view>
        </view>

        <view class="empty" wx:if="{{appealList.length === 0}}">
          <text>暂无待处理申诉</text>
        </view>
      </block>
    </scroll-view>
  </block>
</view>
