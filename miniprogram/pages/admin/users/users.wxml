<navigation-bar title="用户管理" back="{{true}}" color="black" background="#F5F9F0"></navigation-bar>

<view class="page-body">
  <view class="forbidden" wx:if="{{forbidden}}">
    <text class="forbidden-icon">🔒</text>
    <text class="forbidden-title">无访问权限</text>
    <text class="forbidden-desc">仅管理员可管理用户</text>
  </view>

  <scroll-view class="scrollarea" scroll-y type="list" wx:else>
    <view class="page-tip">点击角色可切换，右侧按钮可封禁/解封用户</view>

    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <view class="user-card" wx:for="{{userList}}" wx:key="user_id">
      <image class="user-avatar" src="{{item.avatar_url}}" mode="aspectFill"></image>
      <view class="user-info">
        <view class="user-top">
          <text class="user-name">{{item.nickname}}</text>
          <text class="self-tag" wx:if="{{item.is_self}}">当前账号</text>
        </view>
        <text class="user-account" wx:if="{{item.username}}">账号：{{item.username}}</text>
        <view class="user-meta">
          <view
            class="role-tag {{item.is_self ? 'disabled' : ''}}"
            data-id="{{item.user_id}}"
            bindtap="onChangeRole"
          >{{item.role_label}}</view>
          <text class="status-tag {{item.status === 'banned' ? 'banned' : ''}}">{{item.status_label}}</text>
          <text class="login-time">{{item.last_login_text}}</text>
        </view>
      </view>
      <view
        wx:if="{{!item.is_self}}"
        class="ban-btn {{item.status === 'banned' ? 'unban' : ''}}"
        data-id="{{item.user_id}}"
        bindtap="onToggleBan"
      >{{item.status === 'banned' ? '解封' : '封禁'}}</view>
    </view>

    <view class="empty" wx:if="{{!loading && userList.length === 0}}">
      <text>暂无用户数据</text>
    </view>
  </scroll-view>
</view>
