<navigation-bar extClass="nav-bar-slot" title="校园动植物志" back="{{true}}" color="black" background="#F5F9F0"></navigation-bar>

<view class="page-body">
  <view class="page-header">
    <view class="user-panel">
      <view class="user-info-row">
        <view class="avatar-wrap guide-target-avatar" bindtap="onAvatarTap">
          <image class="user-avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
          <view class="avatar-dot" wx:if="{{hasUnreadNotifications}}"></view>
        </view>
        <view class="user-meta">
          <text class="user-name">{{nickname}}</text>
          <text class="user-role">{{roleLabel}}</text>
        </view>

        <view class="user-menu" wx:if="{{showUserMenu}}">
          <view class="menu-item profile" bindtap="onGoProfile">
            <text>个人中心</text>
            <view class="menu-dot" wx:if="{{hasUnreadNotifications}}"></view>
          </view>
          <view wx:if="{{isReviewer}}" class="menu-item reviewer" bindtap="onGoReviewerQueue">
            待鉴定队列{{pendingIdentificationCount > 0 ? ' (' + pendingIdentificationCount + ')' : ''}}
          </view>
          <view wx:if="{{isAdmin}}" class="menu-item admin" bindtap="onGoAdminUsers">用户管理</view>
          <view wx:if="{{isAdmin}}" class="menu-item admin" bindtap="onGoAdminModeration">内容管控</view>
          <view class="menu-item" bindtap="onLogout">退出登录</view>
        </view>
      </view>

      <view class="map-entry guide-target-map" bindtap="onGoMap">
        <text class="map-entry-icon">🗺</text>
        <text class="map-entry-text">校园地图</text>
        <text class="map-entry-desc">查看观测分布</text>
        <text class="map-entry-arrow">›</text>
      </view>

      <view class="reviewer-entry" wx:if="{{isReviewer}}" bindtap="onGoReviewerQueue">
        <text class="reviewer-entry-icon">🔬</text>
        <view class="reviewer-entry-meta">
          <text class="reviewer-entry-text">待鉴定队列</text>
          <text class="reviewer-entry-desc">认领并完成物种鉴定</text>
        </view>
        <text class="reviewer-entry-badge" wx:if="{{pendingIdentificationCount > 0}}">{{pendingIdentificationCount}}</text>
        <text class="reviewer-entry-arrow">›</text>
      </view>

      <view class="tab-bar">
        <view
          class="tab-item guide-target-feed {{activeTab === 'feed' ? 'active' : ''}}"
          data-tab="feed"
          bindtap="onTabChange"
        >最新分享</view>
        <view
          class="tab-item {{activeTab === 'mine' ? 'active' : ''}}"
          data-tab="mine"
          bindtap="onTabChange"
        >上传记录</view>
        <view
          class="tab-item {{activeTab === 'species' ? 'active' : ''}}"
          data-tab="species"
          bindtap="onTabChange"
        >类别档案</view>
      </view>
    </view>
  </view>

  <obs-filter-bar
    wx:if="{{activeTab !== 'species'}}"
    species-options="{{speciesOptions}}"
    location-options="{{locationOptions}}"
    time-options="{{timeOptions}}"
    species-index="{{speciesIndex}}"
    location-index="{{locationIndex}}"
    time-index="{{timeIndex}}"
    featured-only="{{featuredOnly}}"
    show-reset="{{filterActive}}"
    bind:change="onFilterChange"
    bind:reset="onResetFilter"
  />

  <view class="search-row" wx:if="{{activeTab !== 'species' && showSearch}}">
    <input
      class="search-input"
      placeholder="搜索描述、物种、地点..."
      value="{{searchInput}}"
      focus="{{searchFocus}}"
      confirm-type="search"
      bindinput="onSearchInput"
      bindconfirm="onSearchConfirm"
    />
    <view class="search-clear" wx:if="{{searchInput}}" bindtap="onSearchClear">×</view>
    <view class="search-btn" bindtap="onSearchConfirm">搜索</view>
  </view>

  <scroll-view
    class="scrollarea"
    scroll-y
    type="list"
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bind:refresherrefresh="onPullDownRefresh"
    bind:scrolltolower="onLoadMore"
    lower-threshold="100"
  >
    <block wx:if="{{activeTab === 'feed'}}">
      <view
        class="obs-card"
        wx:for="{{feedList}}"
        wx:key="obs_id"
        bindtap="onCardTap"
        data-id="{{item.obs_id}}"
      >
        <image class="obs-thumb" src="{{item.photo_url}}" mode="aspectFill"></image>
        <view class="featured-badge" wx:if="{{item.is_featured}}">⭐ 精选</view>
        <view class="obs-body">
          <view class="obs-top">
            <image class="publisher-avatar-sm" src="{{item.publisher_avatar_url}}" mode="aspectFill"></image>
            <text class="publisher-name">{{item.publisher_nickname}}</text>
            <text class="status-tag feed" wx:if="{{item.status_label}}">{{item.status_label}}</text>
            <text class="publisher-time">{{item.time_text}}</text>
          </view>
          <text class="obs-note">{{item.note}}</text>
          <view class="obs-bottom">
            <view class="obs-location">
              <text class="location-text">📍 {{item.location_name}}</text>
              <text class="species-text" wx:if="{{item.species_label}}">· {{item.species_label}}</text>
            </view>
            <view class="obs-stats">
              <text class="stat-item">♥ {{item.like_count}}</text>
              <text class="stat-item">💬 {{item.comment_count}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="loading" wx:if="{{loading && feedList.length === 0}}">
        <text>加载中...</text>
      </view>

      <view class="empty" wx:if="{{!loading && feedList.length === 0 && filterActive}}">
        <text class="empty-icon">🔍</text>
        <text class="empty-title">{{searchKeyword ? '没有符合搜索条件的记录' : '没有符合筛选条件的记录'}}</text>
        <text class="empty-desc">{{searchKeyword ? '试试换个关键词或调整筛选条件' : '试试调整物种或时间范围'}}</text>
        <button class="empty-btn" bindtap="onResetFilter">清除筛选</button>
      </view>

      <view class="empty" wx:elif="{{!loading && feedList.length === 0}}">
        <text class="empty-icon">🌿</text>
        <text class="empty-title">还没有人分享校园里的小动物和花草</text>
        <text class="empty-desc">快来当第一个发现者吧</text>
        <button wx:if="{{isObserver}}" class="empty-btn" bindtap="onGoPublish">发布第一条发现</button>
      </view>
    </block>

    <block wx:if="{{activeTab === 'mine'}}">
      <view
        class="obs-card"
        wx:for="{{myList}}"
        wx:key="obs_id"
        bindtap="onCardTap"
        data-id="{{item.obs_id}}"
      >
        <image class="obs-thumb" src="{{item.photo_url}}" mode="aspectFill"></image>
        <view class="featured-badge" wx:if="{{item.is_featured}}">⭐ 精选</view>
        <view class="obs-body">
          <view class="obs-top">
            <text class="status-tag" wx:if="{{item.status_label}}">{{item.status_label}}</text>
            <text class="publisher-time">{{item.time_text}}</text>
          </view>
          <text class="obs-note">{{item.note}}</text>
          <view class="obs-bottom">
            <view class="obs-location">
              <text class="location-text">📍 {{item.location_name}}</text>
              <text class="species-text" wx:if="{{item.species_label}}">· {{item.species_label}}</text>
            </view>
            <view class="obs-stats">
              <text class="stat-item">♥ {{item.like_count}}</text>
              <text class="stat-item">💬 {{item.comment_count}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="loading" wx:if="{{myLoading && myList.length === 0}}">
        <text>加载中...</text>
      </view>

      <view class="empty" wx:if="{{!myLoading && myList.length === 0 && filterActive}}">
        <text class="empty-icon">🔍</text>
        <text class="empty-title">{{searchKeyword ? '没有符合搜索条件的记录' : '没有符合筛选条件的记录'}}</text>
        <text class="empty-desc">{{searchKeyword ? '试试换个关键词或调整筛选条件' : '试试调整物种或时间范围'}}</text>
        <button class="empty-btn" bindtap="onResetFilter">清除筛选</button>
      </view>

      <view class="empty" wx:elif="{{!myLoading && myList.length === 0}}">
        <text class="empty-icon">📷</text>
        <block wx:if="{{isObserver}}">
          <text class="empty-title">你还没有上传过观测记录</text>
          <text class="empty-desc">发布第一条发现，解锁你的校园图鉴</text>
          <button class="empty-btn" bindtap="onGoPublish">上传观测记录</button>
        </block>
        <block wx:else>
          <text class="empty-title">暂无上传记录</text>
          <text class="empty-desc">仅观测者可发布记录</text>
        </block>
      </view>
    </block>

    <block wx:if="{{activeTab === 'species'}}">
      <view
        class="species-card"
        wx:for="{{speciesList}}"
        wx:key="species_name"
        data-name="{{item.species_name}}"
        bindtap="onSpeciesTap"
      >
        <view class="species-header">
          <text class="species-icon">{{item.marker_label}}</text>
          <view class="species-meta">
            <text class="species-name">{{item.species_name}}</text>
            <text class="species-count">共 {{item.record_count}} 条记录 · {{item.latest_time_text}}</text>
          </view>
          <text class="species-arrow">›</text>
        </view>

        <view class="species-photos" wx:if="{{item.preview_photos.length > 0}}">
          <image
            class="species-photo"
            wx:for="{{item.preview_photos}}"
            wx:for-item="photo"
            wx:key="*this"
            src="{{photo}}"
            mode="aspectFill"
          ></image>
        </view>

        <view class="species-info">
          <text class="species-info-item" wx:if="{{item.top_location}}">📍 {{item.is_animal ? '常去' : '常被发现于'}}：{{item.top_location}}</text>
          <text class="species-info-item" wx:if="{{item.is_animal && item.active_periods}}">🕐 活跃：{{item.active_periods}}</text>
        </view>
      </view>

      <view class="loading" wx:if="{{speciesLoading && speciesList.length === 0}}">
        <text>加载中...</text>
      </view>

      <view class="empty" wx:if="{{!speciesLoading && speciesList.length === 0}}">
        <text class="empty-icon">📚</text>
        <text class="empty-title">还没有可汇总的类别档案</text>
        <text class="empty-desc">上传并选择物种类别的观测记录后，将按大类自动生成档案</text>
        <button wx:if="{{isObserver}}" class="empty-btn" bindtap="onGoPublish">上传观测记录</button>
      </view>
    </block>

    <view class="list-status-bar" wx:if="{{activeTab !== 'species'}}">
      <block wx:if="{{showStatusBar}}">
        <text wx:if="{{statusBarLoading}}">加载中...</text>
        <text wx:elif="{{statusBarHasMore}}">上滑加载更多</text>
        <text wx:else>— 没有更多了 —</text>
      </block>
    </view>
  </scroll-view>
</view>

<view class="fab-mask" wx:if="{{fabExpanded}}" bindtap="onCloseFab" catchtouchmove="preventTouchMove"></view>

<view class="fab-dock guide-target-fab" wx:if="{{activeTab !== 'species'}}">
  <view class="fab-sub-items {{fabExpanded ? 'expanded' : ''}}">
    <view class="fab-sub-btn search" catchtap="onFabSearch">
      <text class="fab-sub-icon">🔍</text>
    </view>
    <view class="fab-sub-btn publish" wx:if="{{isObserver}}" catchtap="onFabPublish">
      <text class="fab-sub-icon">+</text>
    </view>
  </view>
  <view class="fab-main {{fabExpanded ? 'active' : ''}}" catchtap="onFabToggle">
    <text class="fab-main-icon">{{fabExpanded ? '×' : '+'}}</text>
  </view>
</view>

<view class="menu-mask" wx:if="{{showUserMenu}}" bindtap="onCloseMenu"></view>

<guide-overlay
  visible="{{guideVisible}}"
  rect="{{guideRect}}"
  title="{{guideTitle}}"
  desc="{{guideDesc}}"
  current-step="{{guideStep + 1}}"
  total-steps="{{guideTotalSteps}}"
  is-last="{{guideStep + 1 >= guideTotalSteps}}"
  radius="{{guideRadius}}"
  bind:next="onGuideNext"
  bind:skip="onGuideSkip"
/>
